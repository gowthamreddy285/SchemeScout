<script type="text/javascript">
    var ServerPath = 'https://www.mudra.org.in/';
    $(function () {
        $('#main-menu').smartmenus({
            subMenusSubOffsetX: 1,
            subMenusSubOffsetY: -8
        }
        );
        $(".ticker1").modernTicker(
        {
            effect: "scroll",
            scrollType: "continuous",
            scrollStart: "inside",
            scrollInterval: 20,
            transitionTime: 500,
            autoplay: true
        }
            );
        $(".ticker2").modernTicker({
            effect: "fade",
            displayTime: 4e3,
            transitionTime: 300,
            autoplay: true
        }
            );
        $(".ticker3").modernTicker({
            effect: "type",
            typeInterval: 10,
            displayTime: 4e3,
            transitionTime: 300,
            autoplay: true
        }
            );
        $(".ticker4").modernTicker({
            effect: "slide",
            slideDistance: 100,
            displayTime: 4e3,
            transitionTime: 350,
            autoplay: true
        }
            );

        $(window).scroll(function () {
            if ($(this).scrollTop() != 0) {
                $("#toTop").fadeIn();
            } else {
                $("#toTop").fadeOut();
            }
        });

        $("#toTop").click(function () {
            $("body,html").animate({ scrollTop: 0 }, 800);
        });

        if ($('.lang-info > span').hasClass('EN selected')) {
            $('.EN').hide();
            $('.HN').show();
        }
        else {
            $('.EN').show();
            $('.HN').hide();
        }

        var ServerPath = 'https://www.mudra.org.in/';
        $('.lang-info > span').click(function () {

            if (!$(this).hasClass('selected')) {
                id = (($(this).hasClass('EN')) ? 'EN' : 'HN');
                id2 = (id == 'EN') ? 'HN' : 'EN';

                $(".lang-info > span").toggle();

                $.getJSON(ServerPath + 'Default/SwitchLang/', { id: id }, function (data) {
                    if (data == true) {
                        $('#langStyle').html(id2 + ' { display:none; }');
                        $('.lang-info > span.' + id).addClass('selected');
                        $('.lang-info > span.' + id2).removeClass('selected');

                        var Lang = $('.lang-info > span').hasClass('EN selected');
                        if (Lang) {
                            $('.fancybox').prop('title', 'Mudra Launch Ceremony');
                        }
                        else {
                            $('.fancybox').prop('title', 'शुभारंभ समारोह - ८ अप्रैल २०१५');
                        }
                    }
                });
            }
        });
    });
</script>
<script type="text/javascript">
    function Updatetxt() {
        debugger;
        if ($('.lang-info > span').hasClass('EN selected')) {
            var srctxt = $("#search_text_en").val();
            if (srctxt == '') {
                alert('Invalid Search.');
            }
            else {
                var ServerPath = 'https://www.mudra.org.in/';
                var text = ServerPath + 'Search/Index?q=' + srctxt;
                console.log(text);
                window.location.href = ServerPath + 'Search/Index?q=' + srctxt;

            }
        }
        else if ($('.lang-info > span').hasClass('HN selected')) {
            var srctxt = $("#search_text_hn").val();
            if (srctxt == '') {
                alert('Invalid Search.');
            }
            else {
                var ServerPath = 'https://www.mudra.org.in/';
                window.location.href = ServerPath + 'Search/Index?q=' + srctxt;
            }
        }
    }
    $('#search_text_en,#search_text_hn').keypress(function (e) {
        var key = e.which;
        if (key == 13) {
            Updatetxt();
            return false;
        }
    });
</script>
<script type="text/javascript">
    // ======================== Font Resize Javascript Starts ========================
    $(document).ready(function () {

        $('#incfont').click(function () {
            curSize = parseInt($('body').css('font-size')) + 2;
            if (curSize <= 16)
                $('body').css('font-size', curSize);
        });

        $('#decfont').click(function () {
            curSize = parseInt($('body').css('font-size')) - 2;
            if (curSize >= 12)
                $('body').css('font-size', curSize);
        });

        $('#orgfont').click(function () {
            curSize = parseInt($('body').css('font-size'));
            if (curSize = 14)
                $('body').css('font-size', curSize);
        });

    });
    // ======================== Font Resize Javascript Ends ========================
</script>
<script type="text/javascript">
    jQuery(document).ready(function ($) {
        $(window).on('load', function () {
            //            $(window).load(function () {
