# ============================================================
# .env.example  —  Copy to backend/.env and fill in real values
# All settings here have defaults in backend/config.py.
# ============================================================

# ── LLM API Keys (at least one required) ──────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=                        # leave blank to skip
ANTHROPIC_API_KEY=                     # leave blank to skip

# ── Model Selection ───────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-base

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────
TOP_K_RETRIEVAL=10
TOP_K_RERANK=3

# ── Rate Limiting (slowapi format: "N/period") ─────────────────
# Controls per-IP request rate limits for the API.
RATE_LIMIT_QUERY=20/minute       # /query endpoint (Groq API calls)
RATE_LIMIT_DEFAULT=60/minute     # all other endpoints
